set nocompatible
syntax on
filetype plugin indent on

set number
set relativenumber
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent
set nowrap
set hidden
set clipboard=unnamed

set cursorline
set scrolloff=8
set showmatch
set laststatus=2
set wildmenu
set incsearch
set hlsearch
set ignorecase
set smartcase

nnoremap <C-s> :w<CR>
inoremap <C-s> <Esc>:w<CR>a
